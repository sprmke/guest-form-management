# =============================================================================
# Supabase Edge Functions env vars — copy to `.env.local` (for `supabase start`)
# and configure the production set via the Supabase dashboard → Project Settings
# → Edge Functions → Secrets.
# =============================================================================
#
# NEVER commit real values. `.env*` files (except this example) are git-ignored.
# The `private_key` in `GOOGLE_SERVICE_ACCOUNT` is a real secret — treat it like
# any other credential and rotate if it ever lands somewhere public.
# =============================================================================
#
# Local Google OAuth for `/sign-in` (GoTrue) reads GOOGLE_CLIENT_ID and
# GOOGLE_CLIENT_SECRET from ui/.env.development — see `ui/.env.example` and
# `scripts/run-with-ui-dev-env.sh` (used by dev.sh / npm run start:supabase).
# =============================================================================


# --- Local prod data sync (optional) ----------------------------------------
# Used by ./scripts/sync-prod-public-data-to-local.sh when not exported in the shell.
# Session pooler URI from Dashboard → Connect (IPv4-friendly). URL-encode special chars in password.
# PROD_DB_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres

# --- Supabase runtime -------------------------------------------------------
# Deployed edge functions: `SUPABASE_URL` + `SUPABASE_SERVICE_ROLE_KEY` are injected
# by the platform.
#
# Local `./dev.sh` / `supabase start`: same vars are injected into the Docker edge
# runtime — you do **not** need them in `.env.local` for that path.
#
# Local `supabase functions serve --env-file ./supabase/.env.local` only: the CLI **skips**
# SUPABASE_* names in --env-file. `./dev.sh` and `npm run dev:api` run
# `scripts/export-local-supabase-runtime-env.sh` first (from `supabase status`). If you
# invoke `functions serve` manually, source that script or export both below, or handlers
# fail with `name resolution failed`.
# SUPABASE_URL=http://127.0.0.1:54321
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...replace...me...
#
# Gmail “Connect Gmail” OAuth redirect_uri must be a URL Google + the browser can open.
# If Edge sets SUPABASE_URL to http://kong:8000, either set this to your public API host
# or rely on the built-in kong→127.0.0.1:54321 fallback in `_shared/gmailMailOAuthAccess.ts`.
# SUPABASE_PUBLIC_URL=http://127.0.0.1:54321
#
# Read by `_shared/databaseService.ts`, `uploadService`, `get-booked-dates`, etc.


# --- Environment flag ------------------------------------------------------
# Read by `_shared/utils.ts#isDevelopment()`. If either `ENVIRONMENT` or `DENO_ENV`
# equals `development`, certain side effects are softened (e.g. calendar/sheet
# labels, email routing). Deployed functions also check `DENO_DEPLOYMENT_ID` (set
# automatically by Supabase) as a production signal in `submit-form`.
ENVIRONMENT=development
# DENO_ENV=development


# --- Resend (transactional email) -----------------------------------------
# https://resend.com/api-keys — read/write or full-access key.
RESEND_API_KEY=re_replace_me

# Primary "to" address for guest-form notifications.
# Dev default:  sprmke.dev@gmail.com
# Prod default: stlmonaco.theresortresidences@azurenorth.com.ph
EMAIL_TO=sprmke.dev@gmail.com

# Reply-To on most outbound Resend mail. Also the **sole To:** address for
# "New Booking Request" (`sendNewBookingRequestNotify`) after each successful
# public `submit-form` DB save (owners / ops inbox).
EMAIL_REPLY_TO=kamehome.azurenorth@gmail.com


# --- Google Calendar + Sheets (service account) ---------------------------
# JSON key for a GCP service account with Calendar + Sheets access.
# Must be a SINGLE-LINE JSON string — newlines inside the `private_key` are
# escaped as `\n`. Read by `_shared/calendarService.ts` and `_shared/sheetsService.ts`.
GOOGLE_SERVICE_ACCOUNT={"type":"service_account","project_id":"replace-me","private_key_id":"replace-me","private_key":"-----BEGIN PRIVATE KEY-----\n...replace-me...\n-----END PRIVATE KEY-----\n","client_email":"replace-me@replace-me.iam.gserviceaccount.com","client_id":"replace-me","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"https://www.googleapis.com/robot/v1/metadata/x509/replace-me%40replace-me.iam.gserviceaccount.com","universe_domain":"googleapis.com"}

# Target calendar (an email-style ID or the raw `calId` from Google Calendar settings).
GOOGLE_CALENDAR_ID=kamehome.azurenorth@gmail.com

# Google Sheets spreadsheet ID (the long token from the sheet URL
# `https://docs.google.com/spreadsheets/d/<THIS>/edit`).
GOOGLE_SPREADSHEET_ID=replace-me-spreadsheet-id


# =============================================================================
# PHASE 3 — admin edge functions + JWT allow list (shipped — mirror into Dashboard secrets for prod)
# =============================================================================
# Set these before deploying `list-bookings`, `transition-booking`,
# `upload-booking-asset`, and `parking-broadcast-email`. See
# `.cursor/rules/admin-auth.mdc` §7, `docs/MIGRATION_RUNBOOK.md` §11 (production checklist),
# and `docs/NEW_FLOW_PLAN.md` §5 (Phase 3).

# Comma-separated Google emails allowed to call admin edge functions.
# Enforced by `_shared/auth.ts#verifyAdminJwt`. THIS is the authoritative gate —
# the UI check (`VITE_ADMIN_ALLOWED_EMAILS`) is a UX reject only.
# ADMIN_ALLOWED_EMAILS=kamehome.azurenorth@gmail.com

# Comma-separated BCC recipients for the parking broadcast email. The initial
# seed list lives in `docs/NEW_FLOW_PLAN.md` §6.1 Q4.1 — never hard-code emails
# in source, rotate via env only. **Also editable:** Admin → Settings (`app_settings`).
# PARKING_OWNER_EMAILS=owner1@example.com,owner2@example.com


# =============================================================================
# PHASE 4 — Gmail listener + SD refund cron
# =============================================================================
#
# --- Option A — In-app “Connect Gmail” on /settings (recommended for operators) ---
# Create a separate OAuth 2.0 **Web application** client in Google Cloud (not the
# same client as Supabase Auth sign-in). Authorized redirect URI must be exactly:
#   {SUPABASE_URL}/functions/v1/google-mail-oauth-callback
# e.g. local: http://127.0.0.1:54321/functions/v1/google-mail-oauth-callback
# Full client JSON download:
# GMAIL_API_WEB_CLIENT_JSON='{"web":{"client_id":"...","client_secret":"...","redirect_uris":["http://127.0.0.1:54321/functions/v1/google-mail-oauth-callback"]}}'
# 32-byte AES key for encrypting refresh tokens in Postgres (64 hex chars OR base64):
# openssl rand -hex 32
# GMAIL_OAUTH_TOKEN_ENCRYPTION_KEY=your_64_hex_chars_here
# Comma-separated SPA origins allowed to start OAuth (must match browser Origin):
# GMAIL_OAUTH_ALLOWED_RETURN_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
#
# --- Option B — Legacy CLI (`npm run gmail-auth`) ---
# Run `npm run gmail-auth` once (from scripts/gmail-credentials.json) to
# populate GMAIL_OAUTH_CLIENT_JSON and GMAIL_OAUTH_TOKEN_JSON in supabase/.env.local.
# Both are full JSON strings — NOT individual fields.

# Full OAuth client JSON (contents of scripts/gmail-credentials.json):
# GMAIL_OAUTH_CLIENT_JSON='{"web":{"client_id":"...","client_secret":"...",...}}'

# Token JSON returned after browser sign-in (contains refresh_token):
# GMAIL_OAUTH_TOKEN_JSON='{"access_token":"...","refresh_token":"...","scope":"...",...}'

# Gmail listener / backfill: when EMAIL_REPLY_TO is set, only approval replies from that
# sender are processed. Leave unset to allow any sender (permissive). Also editable in Settings.
# EMAIL_REPLY_TO=kamehome.azurenorth@gmail.com

# Minutes *before* parsed check-out (Asia/Manila) when `sd-refund-cron` may send the
# guest Check-out & SD Refund email (independent of balance settlement) and evaluate
# auto-transition to READY_FOR_CHECKOUT once settlement is complete. Default: 120.
# SD_REFUND_CRON_EMAIL_LEAD_MINUTES=120

# If check-out was more than this many days ago, sd-refund-cron still transitions
# to READY_FOR_CHECKOUT but skips the guest SD form email. Default: 21. Use 0 to never suppress.
# SD_REFUND_CRON_MAX_CHECKOUT_AGE_DAYS=21

# Optional guest links / branding — editable from Admin → Settings (`app_settings` table).
# When unset in DB, these env vars are fallbacks until saved in the UI.
# PUBLIC_GUEST_APP_ORIGIN=https://kamehomes.space
# FACEBOOK_REVIEWS_URL=https://www.facebook.com/kamehome.azurenorth/reviews
# EMAIL_LOGO_URL=https://kamehomes.space/images/logo.png


# =============================================================================
# Telegram marketing (Settings + cron + submit-form / cancel-booking)
# =============================================================================
# See docs/reference/telegram-marketing-reminders.md
#
# TELEGRAM_BOT_TOKEN=123456:ABC...   # from @BotFather (no spaces)
# TELEGRAM_CHAT_ID=-1001234567890   # numeric id only; no quotes; supergroups often -100...
# TELEGRAM_CRON_SECRET=long-random   # optional; pg_net must send X-Telegram-Cron-Secret when set


# =============================================================================
# Telegram staff/cleaner notifications (Settings + cron)
# =============================================================================
# Daily booking summary to staff/cleaner Telegram group.
# Uses a separate chat id (different group) but can reuse the same bot token.
#
# TELEGRAM_STAFF_BOT_TOKEN=123456:ABC...   # optional; falls back to TELEGRAM_BOT_TOKEN
# TELEGRAM_STAFF_CHAT_ID=-1009876543210   # numeric id for staff group; required for staff sends
# TELEGRAM_STAFF_CRON_SECRET=<openssl rand -hex 32>   # optional; must match Vault telegram_staff_cron_secret
#   Generate:  openssl rand -hex 32
#   Setup:     supabase/snippets/telegram-staff-cron.sql
