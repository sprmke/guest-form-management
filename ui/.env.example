# =============================================================================
# UI / Vite env vars ‚Äî copy to `.env.development` and/or `.env.production`
# =============================================================================
#
# Vite resolves the file by build mode (`npm run dev` ‚Üí `.env.development`,
# `npm run build` ‚Üí `.env.production`). Only variables prefixed with `VITE_`
# are exposed to client code via `import.meta.env.VITE_*`.
#
# NEVER commit real values. All `.env*` files (except this example) are git-ignored.
# =============================================================================


# --- Runtime mode ----------------------------------------------------------
# Consumed by `GuestForm.tsx`: when `production`, the form hides dev controls and
# hard-disables test-booking email delivery. Keep `development` locally even if the
# file points at the prod Supabase project (it often does ‚Äî see below).
VITE_NODE_ENV=development


# --- Supabase project ------------------------------------------------------
# Supabase Edge Functions base URL (includes `/functions/v1` suffix).
# Example (local CLI):  http://127.0.0.1:54321/functions/v1
# Example (prod):       https://<project-ref>.supabase.co/functions/v1
VITE_SUPABASE_URL=https://<project-ref>.supabase.co/functions/v1

# Duplicate of `VITE_SUPABASE_URL` for historical reasons ‚Äî both are read by the
# guest form fetchers (`VITE_API_URL`) and by `ui/src/lib/supabaseClient.ts`
# (`VITE_SUPABASE_URL`). Keep them in sync.
VITE_API_URL=https://<project-ref>.supabase.co/functions/v1

# Anon public key from Supabase dashboard ‚Üí Project Settings ‚Üí API.
# Safe to ship to the browser; it only grants access subject to RLS.
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...replace...me...

# Optional override. If unset, `ui/src/lib/supabaseClient.ts` derives the project
# URL by stripping `/functions/v1` from VITE_SUPABASE_URL. Only set this when you
# want the Supabase JS client to talk to a different project than the functions.
# VITE_SUPABASE_PROJECT_URL=https://<project-ref>.supabase.co


# --- Phase 1: admin dashboard ---------------------------------------------
# Comma-separated Google emails allowed to open `/bookings` and `/sign-in`.
# This is a UX reject only. The authoritative allow list lives server-side
# (see `supabase/.env.example` ‚Üí `ADMIN_ALLOWED_EMAILS`) and ships in Phase 3.
# If this var is empty, every email is rejected (fail closed by design).
VITE_ADMIN_ALLOWED_EMAILS=kamehome.azurenorth@gmail.com


# --- Legacy / optional ----------------------------------------------------
# Historically committed for local Supabase CLI convenience. Not read by the app.
# VITE_SUPABASE_DB_PASSWORD=replace-me
